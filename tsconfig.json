{
	"$schema": "https://json.schemastore.org/tsconfig",
	"extends": "@acdh-oeaw/tsconfig",
	"compilerOptions": {
			"baseUrl": ".",
			"paths": {
					"@/*": ["./src/*"],
					"~/*": ["./*"]
			},
			"plugins": [{ "name": "next" }]
	},
	"include": ["./**/*.ts", "./**/*.tsx", ".next/types/**/*.ts", "./**/*.js"],
	"exclude": ["node_modules", "out"]
}
